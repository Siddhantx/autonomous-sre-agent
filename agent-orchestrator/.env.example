# APOE Active Agent Orchestrator — configuration (env prefix: APOE_)
# Copy to `.env` and override as needed. Defaults target the lab compose network.

APOE_SERVICE_NAME=agent-orchestrator
APOE_ENVIRONMENT=lab
APOE_LOG_LEVEL=INFO

# External systems
APOE_PROMETHEUS_URL=http://prometheus:9090
APOE_POSTGRES_DSN=postgresql://apoe_user:apoe_secure_pass@postgres:5432/enterprise_db
APOE_REDIS_URL=redis://redis:6379/0
APOE_KAFKA_BOOTSTRAP=kafka:29092
APOE_CHAOS_INJECTOR_URL=http://chaos-injector:9999
APOE_LOKI_URL=http://loki:3100

# OpenTelemetry
APOE_OTEL_ENABLED=true
APOE_OTEL_ENDPOINT=http://otel-collector:4317

# Resilience
APOE_AGENT_TIMEOUT_SECONDS=10.0
APOE_MAX_RETRY_ATTEMPTS=5
APOE_RETRY_BACKOFF_SECONDS=1.0
APOE_RETRY_BACKOFF_MAX_SECONDS=15.0

# Safety: set true to plan+evaluate remediations without executing them
APOE_DRY_RUN=false

# LLM investigator (disabled while APOE_LLM_MODEL is empty)
# provider: anthropic | openai (openai covers Ollama/vLLM/any compatible endpoint)
APOE_LLM_PROVIDER=anthropic
APOE_LLM_BASE_URL=
APOE_LLM_MODEL=
APOE_LLM_API_KEY=
APOE_INVESTIGATOR_THRESHOLD=0.7
APOE_INVESTIGATOR_MAX_STEPS=8
APOE_INVESTIGATOR_MAX_TOKENS=4000
APOE_INVESTIGATOR_TIMEOUT_S=30.0

# Knowledge layer (SQLite FTS5)
APOE_KNOWLEDGE_DB_PATH=apoe_knowledge.db
# Defaults resolve relative to the repo; override for non-standard layouts.
#APOE_LAB_SOURCE_PATH=../enterprise-lab
#APOE_RUNBOOKS_PATH=./runbooks

# Governance
# Required by every mutating endpoint (X-API-Key header).
# Empty = all mutating requests rejected (default-deny). Set a real secret.
APOE_API_KEY=
APOE_AUDIT_LOG_PATH=apoe_audit.jsonl
# Consecutive human approvals before suggesting an auto-allow policy rule
APOE_PROMOTION_THRESHOLD=3

# Tool providers: "all" or comma-separated (postgres,redis,kafka,prometheus,logs,kubernetes,code,knowledge)
APOE_TOOL_PROVIDERS=all

# Kubernetes (leave empty to disable the kubernetes tool provider)
APOE_K8S_API_URL=
APOE_K8S_NAMESPACE=default

# Swarm investigation: fan out to specialist sub-investigators
APOE_SWARM_ENABLED=false

# Notifications (leave empty to disable)
APOE_SLACK_WEBHOOK_URL=
APOE_NOTIFY_WEBHOOK_URL=
