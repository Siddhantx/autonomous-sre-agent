# APOE Active Agent Orchestrator — configuration (env prefix: APOE_)
# Copy to `.env` and override as needed. Defaults target the lab compose network.

APOE_SERVICE_NAME=agent-orchestrator
APOE_ENVIRONMENT=lab
APOE_LOG_LEVEL=INFO

# External systems
APOE_PROMETHEUS_URL=http://prometheus:9090
APOE_POSTGRES_DSN=postgresql://apoe_user:apoe_secure_pass@postgres:5432/enterprise_db
APOE_REDIS_URL=redis://redis:6379/0
APOE_KAFKA_BOOTSTRAP=kafka:29092
APOE_CHAOS_INJECTOR_URL=http://chaos-injector:9999

# OpenTelemetry
APOE_OTEL_ENABLED=true
APOE_OTEL_ENDPOINT=http://otel-collector:4317

# Resilience
APOE_AGENT_TIMEOUT_SECONDS=10.0
APOE_MAX_RETRY_ATTEMPTS=5
APOE_RETRY_BACKOFF_SECONDS=1.0

# Safety: set true to plan+evaluate remediations without executing them
APOE_DRY_RUN=false
